# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# The schema is enforced in `env.js` — the app won't start if a required
# variable is missing or invalid.

# --- NextAuth ---
# Generate a secret with: npx auth secret
AUTH_SECRET=""
AUTH_DISCORD_ID=""
AUTH_DISCORD_SECRET=""

# --- Database (Prisma) ---
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# --- FastAPI backend (น้องกอฟ QA assistant) ---
# Base URL of the FastAPI backend that the SSE proxy (app/api/proxy-sse)
# forwards chat requests to. Read server-side.
NEXT_PUBLIC_FASTAPI_URL="http://localhost:8000"

# Optional: absolute origin the browser uses to reach THIS app's own /api
# routes. Leave unset for same-origin (relative) requests.
# NEXT_PUBLIC_REVERSE_URL="https://your-app.example.com"

# Shared secret presented as the X-API-Key header to the backend. MUST match
# the backend's API_KEY (its .env). Minimum 16 characters. Server-side only —
# never exposed to the browser.
FASTAPI_API_KEY="generate-a-secret-at-least-16-chars"
